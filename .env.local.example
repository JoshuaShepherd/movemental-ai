# Copy this file to .env.local and fill in real values, OR run:
#   vercel link
#   vercel env pull .env.local --yes
#
# Shared secrets (Josh's machine): merge from ~/Desktop/Dev/.env.shared into .env.local:
#   pnpm env:local-from-shared
#
# Push the same movemental-relevant keys to the linked Vercel project (prod + preview + dev):
#   pnpm vercel:env:sync
# Optional: DEV_DOTENV_SHARED_PATH=/path/to/.env.shared
#
# Required by src/lib/env.ts and validated by `pnpm check:env`.

# Supabase — browser-safe keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres connection string used by Drizzle (server-only).
# For Supabase, use the "Connection pooling" URI from project settings.
DATABASE_URL=

# --- Optional ---

# Server-only Supabase admin key. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL (used for metadata, redirects). Defaults to https://movemental.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional profile URLs — when set, appear in the site footer (social row).
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/…
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/…
# NEXT_PUBLIC_SOCIAL_BLUESKY_URL=https://bsky.app/profile/…

# Multi-tenant org id (newsletter + DB scoping). From shared env or Vercel.
# Required for POST /api/newsletter — without it signups return 503.
TENANT_ORG_ID=

# Resend (transactional email — book flows, contact ack, optional team notify).
# Create key + verify domain: https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional: display name in From header, e.g. Movemental
RESEND_FROM_NAME=
# Optional: internal inbox for new /api/contact submissions (Reply-To = submitter).
CONTACT_NOTIFY_EMAIL=
# Recommended (≥16 random chars): HMAC for one-click newsletter unsubscribe in confirmation email.
# Generate: openssl rand -hex 24
NEWSLETTER_UNSUBSCRIBE_SECRET=

# Secret gate for /book/moderate — generate locally; not in shared bundle by default.
BOOK_MODERATION_TOKEN=

# Sentry — error monitoring (optional; monitoring is disabled when DSN is unset)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
