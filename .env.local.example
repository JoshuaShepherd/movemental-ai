# =============================================================================
# Movemental marketing site (movemental-ai) — environment template
# =============================================================================
# Copy to `.env.local` or merge from your shared bundle / Vercel:
#   vercel link && vercel env pull .env.local --yes
#   pnpm env:local-from-shared   # optional merge from DEV_DOTENV_SHARED_PATH
#
# Database: use the shared Movemental Supabase Postgres project (transaction
# pooler URI recommended for Next.js server/runtime — see bootstrap doc).
#
# Required for `pnpm check:env` + runtime (see src/lib/env.ts):
# =============================================================================

# Supabase — public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres for Drizzle — pooler connection string (server-only)
DATABASE_URL=

# --- Optional but commonly set ------------------------------------------------

# Server-only Supabase admin key (server actions, bypass RLS — never in client)
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL (metadata, redirects). Production: https://movemental.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Org UUID for multi-tenant newsletter + DB scoping — required for POST /api/newsletter
# Resolve: Supabase SQL → select id, slug from organizations;
TENANT_ORG_ID=

# Optional footer / JSON-LD socials
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/…
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/…
# NEXT_PUBLIC_SOCIAL_BLUESKY_URL=https://bsky.app/profile/…

# Resend — transactional email (contact, book flows, etc.)
# https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=
CONTACT_NOTIFY_EMAIL=
NEWSLETTER_UNSUBSCRIBE_SECRET=

# Book moderation tooling — `/book/moderate`
BOOK_MODERATION_TOKEN=

# Stripe — leader onboarding PaymentIntent uses STRIPE_SECRET_KEY on this app
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Leader onboarding PaymentIntent amount (USD cents). Minimum 50. Example: 50000 = $500.
ONBOARDING_PAYMENT_AMOUNT_CENTS=100

# Secures GET /api/cron/onboarding-reminders — send Authorization: Bearer <secret>
CRON_SECRET=

# Sentry — optional (monitoring off when DSN unset)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Onboarding: Calendly (optional) ------------------------------------------
# AI Sandbox cohort training — embeds on /sandboxlive/cohort/schedule (per-org override in organizations.settings.calendly_training_url)
NEXT_PUBLIC_CALENDLY_TRAINING_URL=https://calendly.com/joshuajordanshepherd/ai-sandbox-cohort-training
# Calendly webhook signing key (from webhook subscription in Calendly admin)
# CALENDLY_WEBHOOK_SIGNING_KEY=

# --- Agent Room (/agent) -------------------------------------------------------
# Mode: hybrid (default) | stub (offline) | stream (legacy full-AI)
# NEXT_PUBLIC_AGENT_ROOM_MODE=hybrid
# Discuss phase — longer-form chat surface (wrapping voice band + on-sheet transcript). 1 = enabled.
NEXT_PUBLIC_AGENT_ROOM_DISCUSS=1
# Max assistant turns before Discuss offers a human hand-off (default 7).
# NEXT_PUBLIC_AGENT_ROOM_DISCUSS_TURN_CAP=7
#
# Live agent engine (movemental-ai-agents). Local dev:
#   AI_AGENTS_BASE_URL=http://localhost:3001
# Production (Vercel): https://movemental-ai-agents.vercel.app
# AI_AGENTS_BASE_URL=
# AI_AGENTS_SERVICE_SECRET=
# AI_AGENTS_TENANT_ORG_ID=   # same org as TENANT_ORG_ID / engine TENANT_ORG_ID
