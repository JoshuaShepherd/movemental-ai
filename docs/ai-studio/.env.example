# =============================================================================
# AI Studio (Vite app under movemental-ai/docs/ai-studio)
# =============================================================================
# Copy to `.env` in this directory (Vite loads via loadEnv — see vite.config.ts).
#
# Bootstrap walkthrough:
#   ../../build/plans/movemental-multi-repo-env-bootstrap.md
# =============================================================================

# Required for Gemini calls — Google AI Studio / Gemini API
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Hosted applet URL (Cloud Run / deployed origin). Local dev:
APP_URL=http://localhost:3000

# When agents edit files, disabling HMR reduces flicker (optional)
# DISABLE_HMR=true
