{
  "name": "movemental",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/sync-hero-previews.ts && next dev",
    "sync:hero-previews": "tsx scripts/sync-hero-previews.ts",
    "prebuild": "tsx scripts/sync-hero-previews.ts && tsx scripts/pre-build-check.ts",
    "build:check": "tsx scripts/pre-build-check.ts",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "NODE_OPTIONS=\"--max-old-space-size=8192\" tsc --noEmit",
    "drizzle:gen": "drizzle-kit generate",
    "drizzle:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "check:env": "tsx scripts/check-env.ts",
    "smoke:comms": "tsx scripts/smoke-comms-env.ts",
    "ssot:movemental-ai-path:markdown": "node scripts/ssot-raw-txt-to-markdown.mjs",
    "reader:sync": "node docs/reader/sync-manifest.mjs",
    "sync:stitch-spec": "tsx scripts/sync-stitch-spec.ts",
    "program:fixtures:check": "tsx scripts/validate-stitch-fixtures.ts",
    "reader:check": "node docs/reader/sync-manifest.mjs --check",
    "reader:serve": "node scripts/docs-static-server.mjs",
    "reader:alan-hirsch-collated": "node scripts/open-alan-hirsch-collated.mjs",
    "reader:mlr:sync": "node docs/movement_leader_research/generate-manifest.mjs",
    "reader:mlr": "node scripts/mlr-reader.mjs",
    "docs:alan-hirsch-research-html": "tsx scripts/build-alan-hirsch-research-collated-html.ts",
    "reader:roy-moran": "node docs/movement_leader_research/generate-manifest.mjs && node scripts/mlr-reader.mjs roy-moran README.md",
    "docs:sync-movement-voices-html": "tsx scripts/sync-movement-voices-html-data.ts && python3 scripts/generate-movement-voices-html-app-js.py",
    "docs:generate-scenius-network-v3": "python3 scripts/generate-scenius-network-v3-html.py",
    "env:local-from-shared": "node scripts/merge-env-local-from-shared.mjs",
    "vercel:env:sync": "node scripts/sync-vercel-env-from-shared.mjs",
    "vercel:link": "vercel link",
    "vercel:git:connect": "vercel git connect --yes",
    "vercel:pull": "vercel env pull .env.local --yes",
    "env:vercel:pull-all": "vercel env pull .env.vercel.production --environment production --yes && vercel env pull .env.vercel.preview --environment preview --yes && vercel env pull .env.vercel.development --environment development --yes && node scripts/sync-env-local-from-vercel-pulls.mjs",
    "db:check": "tsx scripts/validate-db-alignment.ts",
    "contracts:check": "tsx scripts/validate-semantic-alignment.ts",
    "services:check": "tsx scripts/validate-services-alignment.ts",
    "routes:check": "tsx scripts/validate-routes-alignment.ts",
    "hooks:check": "tsx scripts/validate-hooks-alignment.ts",
    "articles:check": "tsx scripts/validate-article-frontmatter.ts",
    "articles:check:warn": "tsx scripts/validate-article-frontmatter.ts --warn",
    "course:scaffold:sandbox": "tsx scripts/scaffold-sandbox-ai-nonprofits-course.ts",
    "course:validate:sandbox": "tsx scripts/validate-sandbox-course-structure.ts",
    "validate:all": "tsx scripts/validate-semantic-alignment.ts && tsx scripts/validate-services-alignment.ts && tsx scripts/validate-routes-alignment.ts && tsx scripts/validate-hooks-alignment.ts && tsx scripts/validate-article-frontmatter.ts --warn",
    "generate:schemas": "tsx scripts/generate-zod-schemas.ts",
    "generate:services": "tsx scripts/generate-services.ts",
    "generate:routes": "tsx scripts/generate-routes.ts",
    "generate:hooks": "tsx scripts/generate-hooks.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "field-guide:pdf": "tsx scripts/build-field-guide-pdf.mts",
    "docs:youthfront-2026-guide:pdf": "tsx scripts/generate-youthfront-2026-guide-pdf.ts",
    "docs:pre-sandbox-ai-assessment-catalog-pdf": "tsx scripts/generate-pre-sandbox-ai-assessment-catalog-pdf.mts",
    "leader:sync-corpus": "tsx scripts/sync-leader-corpus.ts",
    "leader:sync-corpus-dashboard": "tsx scripts/sync-leader-corpus-dashboard.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "graphology": "^0.26.0",
    "gsap": "^3.14.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "sigma": "^3.0.2",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "marked": "^18.0.3",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vercel": "^53.1.0",
    "vitest": "^4.1.4"
  }
}
